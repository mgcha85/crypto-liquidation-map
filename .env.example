# Crypto Liquidation Map - Environment Variables

# =============================================================================
# Binance API (Required for live trading)
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# =============================================================================
# Telegram Notifications (Optional)
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Live Trading
# =============================================================================
INITIAL_CAPITAL=10000

# =============================================================================
# Data Paths
# =============================================================================
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_CACHE_DIR=data/cache

# =============================================================================
# Database
# =============================================================================
DUCKDB_PATH=data/liquidation.duckdb

# =============================================================================
# Download Settings
# =============================================================================
DOWNLOAD_MAX_CONCURRENT=5
DOWNLOAD_RETRY_COUNT=3
DOWNLOAD_TIMEOUT_SECONDS=30

# =============================================================================
# Analysis Settings
# =============================================================================
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_LEVERAGE_DISTRIBUTION=10:0.30,25:0.35,50:0.25,100:0.10
PRICE_BUCKET_SIZE=100

# =============================================================================
# Visualization
# =============================================================================
PLOTLY_DEFAULT_WIDTH=1200
PLOTLY_DEFAULT_HEIGHT=800
